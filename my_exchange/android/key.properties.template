# Template for Android release signing
# 1. Generate a keystore: keytool -genkey -v -keystore my-exchange-key.jks -keyalg RSA -keysize 2048 -validity 10000 -alias my-exchange
# 2. Copy this file as key.properties and fill in your values
# 3. Place the .jks file in the android/ directory
#
# WARNING: Never commit key.properties or .jks to version control!

storeFile=my-exchange-key.jks
storePassword=YOUR_STORE_PASSWORD
keyAlias=my-exchange
keyPassword=YOUR_KEY_PASSWORD
