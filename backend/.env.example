# Django Settings
SECRET_KEY=django-insecure-change-this-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,dev.phantom-ink.online,dev.phantom-ink.online

# Database
DB_NAME=my_exchange
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://dev.phantom-ink.online,https://phantom-ink.online

# Backup
BACKUP_KEEP_DAYS=30

# Notifications
NOTIFY_LOW_CASH_THRESHOLD=1000
